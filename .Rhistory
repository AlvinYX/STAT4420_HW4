installed.packages()
"bspm" %in% rownames(installed.packages())
banned_pkgs <- c("gptstudio", "chattr", "askgpt", "chatgpt", "openai",
"ellmer", "mall", "tidyllm", "rollama", "gemini.R")
installed <- rownames(installed.packages())
violations <- intersect(banned_pkgs, installed)
if (length(violations) > 0) {
stop(paste("\n\nUnauthorized AI packages detected ->",
paste(violations, collapse = ", "),
"\nYou must run remove.packages('package_name') in your console to uninstall them before this exam will compile.\n\n"))
} else {
message("System check passed: No known AI packages detected.")
}
