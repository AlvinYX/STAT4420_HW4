# 1. Determine how many samples we have (should be 1000)
num_samples <- length(alpha_final)
# 2. Draw the underlying rate (theta) for the NEW street
# using your 1000 independent samples of alpha and beta
theta_new <- rgamma(num_samples, shape = alpha_final, rate = beta_final)
# 3. Draw the actual observed traffic (y) from a Poisson distribution
# using the newly drawn rates
y_new <- rpois(num_samples, lambda = theta_new)
# 4. Calculate the 95% predictive interval for the actual traffic
predictive_interval <- quantile(y_new, probs = c(0.025, 0.975))
# Print the final result
cat("95% Predictive Interval for total traffic on a new residential street with a bike lane:\n")
print(predictive_interval)
