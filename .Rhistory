scale_x_continuous(breaks = c(2030, 2033, 2037, 2041, 2045)) +
scale_y_continuous(expand = c(0, 0)) +
coord_cartesian(clip = "off") +
labs(x = "", y = "") +
theme_minimal() +
theme(
axis.line.x = element_line(linewidth = .75),
panel.grid = element_blank(),
axis.text.y = element_blank(),
axis.text.x = element_text(color = "black", size = 10, margin = margin(5, 0, 0, 0)),
plot.margin = margin(20, 150, 20, 20),
legend.position = "none"
)
plot
#| label: revenue-plot
#| fig-width: 10
#| fig-height: 5
pal <- c("United States" = "#6D5A75", "European Union" = "#8C7597", "Rest of World" = "#B495C2")
region_order <- c("Rest of World", "European Union", "United States")
# 1. Milestones remain untouched at 2033, 2037, 2041, 2045
milestones <- tidy_revenue %>%
filter(Year %in% c(2033, 2037, 2041, 2045)) %>%
group_by(Year) %>%
summarize(Total_Rev = sum(Revenue, na.rm = TRUE))
# Generate the Stacked Area Plot
plot <- tidy_revenue %>%
# 2. Filter data to start at 2030 and end at 2045
filter(Year >= 2030 & Year <= 2045) %>%
mutate(Region = factor(Region, levels = region_order)) %>%
ggplot(aes(x = Year, y = Revenue, fill = Region, color = Region)) +
geom_area() +
# 3. Title Annotation: Moved x back to 2030 to align with the new start of the plot
annotate("text", x = 2030, y = max(milestones$Total_Rev) * 0.7,
label = "", # Slide Label
hjust = 0, size = 8, lineheight = .9, fontface = "bold", color = "black") +
# 2033 Segment (Start of Revenue)
geom_segment(aes(x = 2033, y = 0, xend = 2033, yend = milestones$Total_Rev[1] * 1.1), color = "black") +
geom_point(aes(x = 2033, y = milestones$Total_Rev[1] * 1.1), color = "black") +
annotate("text", x = 2033, y = milestones$Total_Rev[1] * 3.0,
label = dollar(milestones$Total_Rev[1], scale = 1e-6, suffix = "M", accuracy = 1),
hjust = 0.5, size = 4, fontface = "bold", color = "black") +
# 2037 Segment
geom_segment(aes(x = 2037, y = 0, xend = 2037, yend = milestones$Total_Rev[2] * 1.1), color = "black") +
geom_point(aes(x = 2037, y = milestones$Total_Rev[2] * 1.1), color = "black") +
annotate("text", x = 2037, y = milestones$Total_Rev[2] * 1.15,
label = dollar(milestones$Total_Rev[2], scale = 1e-6, suffix = "M", accuracy = 1),
hjust = 0.5, size = 4, fontface = "bold", color = "black") +
# 2041 Segment
geom_segment(aes(x = 2041, y = 0, xend = 2041, yend = milestones$Total_Rev[3] * 1.1), color = "black") +
geom_point(aes(x = 2041, y = milestones$Total_Rev[3] * 1.1), color = "black") +
annotate("text", x = 2041, y = milestones$Total_Rev[3] * 1.15,
label = dollar(milestones$Total_Rev[3], scale = 1e-6, suffix = "M", accuracy = 1),
hjust = 0.5, size = 4, fontface = "bold", color = "black") +
# 2045 Segment (End of Actual Model)
geom_segment(aes(x = 2045, y = 0, xend = 2045, yend = milestones$Total_Rev[4] * 1.1), color = "black") +
geom_point(aes(x = 2045, y = milestones$Total_Rev[4] * 1.1), color = "black") +
annotate("text", x = 2045, y = milestones$Total_Rev[4] * 1.15,
label = dollar(milestones$Total_Rev[4], scale = 1e-6, suffix = "M", accuracy = 1),
hjust = 0.5, size = 4, fontface = "bold", color = "black") +
# Scales and Styling
scale_fill_manual(values = pal) +
scale_color_manual(values = pal) +
# 5. Add 2030 to x-axis breaks to reflect the new plot start year
scale_x_continuous(breaks = c(2030, 2033, 2037, 2041, 2045)) +
scale_y_continuous(expand = c(0, 0)) +
coord_cartesian(clip = "off") +
labs(x = "", y = "") +
theme_minimal() +
theme(
axis.line.x = element_line(linewidth = .75),
panel.grid = element_blank(),
axis.text.y = element_blank(),
axis.text.x = element_text(color = "black", size = 10, margin = margin(5, 0, 0, 0)),
plot.margin = margin(20, 150, 20, 20),
legend.position = "none"
)
plot
ggsave(filename = "Projected_Revenue_Plot.svg",
plot = plot,
width = 10,
height = 5)
